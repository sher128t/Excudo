{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "framework": "react-router",
    "buildCommand": "npm run build",
    "installCommand": "npm install",
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Cross-Origin-Embedder-Policy",
                    "value": "require-corp"
                },
                {
                    "key": "Cross-Origin-Opener-Policy",
                    "value": "same-origin"
                }
            ]
        }
    ]
}